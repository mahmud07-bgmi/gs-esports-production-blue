<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>BGMI Live Scoreboard</title>

<style>
body{
    margin:0;
    background:transparent;
    font-family:'Segoe UI',sans-serif;
}

.table-container{
    position:absolute;
    right:0;
    top:0;
}

table{
    border-collapse:collapse;
    width:420px;
    color:white;
    font-weight:600;
}

thead{
    background:linear-gradient(to right,#00c6ff,#0072ff);
}

th{
    padding:12px;
    font-size:15px;
    text-align:center;
    letter-spacing:1px;
}

tbody tr{
    background:#1e293b;
}

tbody tr:nth-child(even){
    background:#0f3b4a;
}

td{
    padding:10px;
    font-size:14px;
    text-align:center;
}

td:first-child{
    color:#00eaff;
    font-weight:bold;
}

.team{
    display:flex;
    align-items:center;
    gap:8px;
    justify-content:left;
}

.team img{
    width:30px;
    height:30px;
    border-radius:6px;
    border:2px solid #00eaff;
}

.alive-box{
    display:flex;
    gap:4px;
    justify-content:center;
    position:relative;
}

/* Normal alive bar */
.bar{
    width:10px;
    height:22px;
    background:#00eaff;
    border-radius:3px;
    box-shadow:0 0 6px #00eaff;
}

/* Dead bar */
.bar.dead{
    background:transparent;
    border:2px solid #123a4a;
    box-shadow:none;
}

/* TEAM WIPE LINE */
.wipe-line{
    position:absolute;
    top:50%;
    left:0;
    width:100%;
    height:4px;
    background:#00eaff;
    transform:translateY(-50%);
    box-shadow:0 0 8px #00eaff;
}

td:last-child{
    color:#00eaff;
    font-weight:bold;
}
</style>
</head>

<body>

<div class="table-container">
<table>
<thead>
<tr>
<th>#</th>
<th>TEAM</th>
<th>ALIVE</th>
<th>PTS</th>
</tr>
</thead>
<tbody></tbody>
</table>
</div>

<script>

const sheetURL = "https://opensheet.elk.sh/1vBy-EyuauL1EpdhafLOrp_1xAYDm3paM6eiSUxUpUUE/alive_status";

function loadData(){

fetch(sheetURL)
.then(res => res.json())
.then(data => {

    const tbody = document.querySelector("tbody");
    tbody.innerHTML = "";

    data.forEach((team, index) => {

        let aliveCount = parseInt(team.players_alive) || 0;
        let aliveHTML = '<div class="alive-box">';

        for(let i=0;i<4;i++){
            if(i < aliveCount){
                aliveHTML += '<div class="bar"></div>';
            } else {
                aliveHTML += '<div class="bar dead"></div>';
            }
        }

        // ðŸ”¥ If team wiped
        if(aliveCount === 0){
            aliveHTML += '<div class="wipe-line"></div>';
        }

        aliveHTML += '</div>';

        let totalPoints =
            (parseInt(team.finish_points) || 0) +
            (parseInt(team.position_points) || 0);

        tbody.innerHTML += `
        <tr>
            <td>${index+1}</td>
            <td class="team">
                <img src="${team.team_logo}">
                ${team.team_initial}
            </td>
            <td>${aliveHTML}</td>
            <td>${totalPoints}</td>
        </tr>`;
    });

});
}

loadData();
setInterval(loadData, 1000);

</script>

</body>
</html>
